{
  "name": "otto",
  "version": "0.10.9",
  "description": "General-purpose computer coworking agent",
  "main": "out/main/index.js",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "predev": "node scripts/ensure-abi.mjs electron && node scripts/codesign-dev.mjs",
    "dev": "electron-vite dev",
    "mobile": "npm --prefix otto-mobile start",
    "mobile:install": "npm --prefix otto-mobile install --legacy-peer-deps",
    "dev:all": "concurrently -n desktop,mobile -c blue,magenta \"npm run dev\" \"npm run mobile\"",
    "prebuild": "node scripts/ensure-abi.mjs electron && node scripts/fetch-embedding-model.mjs",
    "build": "electron-vite build && vite build --config vite.config.pwa.ts",
    "build:pwa": "vite build --config vite.config.pwa.ts",
    "start": "electron-vite preview",
    "icons": "node scripts/generate-app-icons.mjs",
    "prepackage": "node scripts/ensure-abi.mjs electron && node scripts/generate-app-icons.mjs",
    "package": "electron-vite build && electron-builder",
    "pretest": "node scripts/ensure-abi.mjs node",
    "test": "vitest run",
    "test:watch": "node scripts/ensure-abi.mjs node && vitest",
    "test:integration": "node scripts/ensure-abi.mjs electron && playwright test",
    "toggle": "node out/main/index.js toggle",
    "toggle:dev": "node out/main/index.js toggle --dev",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint . --ext .ts,.tsx",
    "tray-icon": "node scripts/generate-tray-icon.mjs",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@xenova/transformers": "^2.17.2",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.10.0",
    "dbus-next": "^0.10.2",
    "electron-log": "^5.2.0",
    "electron-updater": "^6.8.3",
    "emoji-regex": "^10.6.0",
    "lucide-react": "^1.16.0",
    "onnxruntime-node": "^1.19.2",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.33.5",
    "shiki": "^4.1.0",
    "sqlite-vec": "^0.1.6",
    "unicode-emoji-json": "^0.9.0",
    "ws": "^8.21.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/hast": "^3.0.4",
    "@types/node": "^22.9.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/unist": "^3.0.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^25.0.1",
    "node-addon-api": "^8.8.0",
    "png2icons": "^2.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "unist-util-visit": "^5.1.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.5"
  }
}
